{% extends 'base.html.twig' %}

{% block title %}Test API!
{% endblock %}

{% block body %}

	<div class="container text-center">
		<h1>Les pokemons du Feu</h1>
		<ul class="list-group">
			{% for pokemon in pokemons %}
				<li class="list-group-item">
					<img src="{{ pokemon.sprite }}" alt="{{ pokemon.name }}" width="10%" height="auto">
					{{ pokemon.name }}
				</li>
			{% endfor %}
		</ul>
	</div>
{% endblock %}
