{% extends 'base.html.twig' %}

{% block title %}Test API!
{% endblock %}

{% block body %}


	<h1>Les pokemons du Feu</h1>
	<ul class="text-decoration-none">
		{% for pokemon in pokemons %}
			<li>
				<img src="{{ pokemon.sprite }}" alt="{{ pokemon.name }}">
				{{ pokemon.name }}
			</li>
		{% endfor %}
	</ul>
{% endblock %}
