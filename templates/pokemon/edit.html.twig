	{% extends 'base.html.twig' %}

{% block title %}Modifier
	{{ pokemon.name }}
{% endblock %}

{% block body %}
	<div class="container-sm p-5">
		<div
			class="d-flex justify-content-between">
			{# <div class="card mx-auto bg-transparent"> #}
			<div class="p-5 align-middle">
				<h3 class="text-center text-light text-uppercase">Modifier
					{{ pokemon.name }}</h3>
				<img src="{{asset('uploads/image/' ~ pokemon.image)}}" alt="" style='width:300px'>
			</div>
			
			{{ include('pokemon/_form.html.twig', {'button_label': 'Enregistrer'}) }}

			<div class="text-center mx-auto align-middle">
				<a class="btn btn-warning" href="{{ path('app_pokemon_index') }}">Retour à la liste</a>
				{{ include('pokemon/_delete_form.html.twig') }}
			</div>
		</div>
	</div>
</div>{% endblock %}
