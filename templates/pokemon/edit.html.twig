{% extends 'base.html.twig' %}

{% block title %}Modifier
	{{ pokemon.name }}
{% endblock %}

{% block body %}
	<div class="container  ">
		<div
			class="row align-middle">
			{# <div class="card mx-auto bg-transparent"> #}
			<div class="col-lg-5 ">

				<div class="w-75 align-center">
					<h3 class="text-center text-light text-uppercase bg-intro text-white  border-success border-4 border rounded-pill fw-bolder">
						Modifier
						{{ pokemon.name }}</h3>
				</div>

				<div class="w-75">
					<img src="{{asset('uploads/image/' ~ pokemon.image)}}" alt="" style='width:300px'>
				</div>

				<button>
					<a class="btn btn-warning text-yellow nodecoration bg-buttonM" href="{{ path('app_pokemon_index') }}">Retour à la liste</a>
				</button>
				<button>
					{{ include('pokemon/_delete_form.html.twig') }}
				</button>


			</div>


			<div class=" col-lg-7 text-center align-middle fs-4">
				{{ include('pokemon/_form.html.twig', {'button_label': 'Enregistrer'}) }}
			</div>

			{# <div class="d-flex">
							<button>
								<a class="btn btn-warning text-yellow nodecoration" href="{{ path('app_pokemon_index') }}">Retour à la liste</a>
							</button>
						</div>
						{{ include('pokemon/_delete_form.html.twig') }} #}


		</div>


	</div>
{% endblock %}
