{% extends 'base.html.twig' %}

{% block title %}
    Découvrir {{ pokemon.name }}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('app') }}
    <style>
        body {
            background-image: url('{{ asset('uploads/Image/' ~ illustration) }}');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="container mx-auto">
        <div class="row">
            <div class="col-5 bg-accueil text-light border-success border-4 border rounded-pill mx-auto mb-2">
                <h1 class="display-5 text-center fw-bolder">Découvrir {{ pokemon.name }}</h1>
            </div>
        </div>
        <div class="row justify-content-between">
            {# colonne gauche #}
            <div class="col-md-5 bg-light text-primary text-center my-3 border rounded-4">
                <h3>Son histoire</h3>
                <h5>{{ pokemon.description }}</h5>
                <div class="text-primary">
                    <h3>Son élément</h3>
                    <h2>{{ pokemon.element.specificite ?? 'Non spécifié' }}</h2>
                    <h3>Sa force</h3>
                    <h2>{{ pokemon.level }}</h2>
                </div>
                {# bouton vers page Team #}
                <a href="{{ path('app_pokemon_index') }}" class="btn btn-warning btn-sm">Retour à la liste</a>
               
                <button id="openOffcanvas" class="btn btn-primary">Ouvrir Offcanvas</button>
            </div>

            {# Colonne droite #}
            <div class="col-md-5 text-primary text-center my-3 border rounded-4 border-light">
                <div class="text-center mb-5">
                    <img src="{{ asset('uploads/Image/' ~ pokemon.image) }}" class="img-fluid" alt="">
                </div>
            </div>
        </div>
    </div>

    {# Offcanvas #}
    <div id="offcanvasOverlay" class="offcanvas-overlay"></div>

    <div id="offcanvas" class="offcanvas">
        <div class="offcanvas-header">
            <h2>Menu Offcanvas</h2>
            <button id="closeOffcanvas" class="btn-close" aria-label="Close">&times;</button>
        </div>
        <div class="offcanvas-content">
            <p>Voici le contenu de l'offcanvas.</p>
            <ul>
                <li>Option 1</li>
                <li>Option 2</li>
                <li>Option 3</li>
            </ul>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('app') }}
    {{ encore_entry_script_tags('offcanvas') }}
{% endblock %}
