{% extends 'base.html.twig' %}
{% block title %}
	Découvrir
	{{ pokemon.name }}
{% endblock %}

{% block body %}
	<body style="background-image: url('{{ asset('uploads/Image/' ~ illustration) }}'); background-size: cover; background-position: center;">
		<div class="container ">
			<h1 class="text-primary text-uppercase display-2 text-center">Découvrir
				{{ pokemon.name }}</h1>

			<div class="row">

				<div class="col-6 text-primary text-center mx-auto my-auto">
					<h3>Son histoire</h3>
					<h5 class="bg-light">{{ pokemon.description }}</p>
					<div class="text-primary">
					<h3>Son élément</h3>
						<h2>{{ pokemon.element.specificite}}</h2>
						<h3>Sa force</h3>
						<h2>{{ pokemon.level }}</h2>
					</div>
					{# <div>
						<img src="{{asset('uploads/Image/' ~ pokemon.element.illustration)}}" alt="" style='width:60px'>
					</div> #}
				</div>

				<div class="col-6  ">
					<div class="text-center">
						<img src="{{asset('uploads/Image/' ~ pokemon.image)}}" alt="" style='width:300px'>
					</div>
					<div class="text-center align-center">
						<a href="{{ path('app_pokemon_index') }}" class="btn btn-warning">Retour à la liste</a>

						<a href="{{ path('app_pokemon_edit', {'id': pokemon.id}) }}" class="btn btn-warning">Modifier</a>

						<button>{{ include('pokemon/_delete_form.html.twig') }}</button>
					</div>

				</div>
			</div>
		</div>
	</body>
</div>{% endblock %}
