{% extends 'base.html.twig' %}
{% block title %}
	{{ pokemon.name }}
{% endblock %}

{% block body %}
	<div class="container-fluid ">
		<div class="row d-flex">
			<div class="col-3">
				<div class="d-inline-block">
					<img src="{{asset('uploads/image/' ~ pokemon.image)}}" alt="" style='width:300px'>
				</div>
			</div>
			<div
				class="col-3">
				{# <th>Description</th> #}
				<div class="text-dark text-center">
					<h3>{{ pokemon.name }}</h3>
					<h5 class="bg-light">{{ pokemon.description }}</p>
				</div>
			</div>
		</div>


		<div class="col-3">
			<div class="text-light">


				<h2>{{ pokemon.name }}</h2>
				<h2>{{pokemon.element.type}}</h2>
				<h2>{{ pokemon.level }}</h2>
			</div>
		</div>

	</div>


	<div class="text-center">
		<a href="{{ path('app_pokemon_index') }}" class="btn btn-warning">back to list</a>

		<a href="{{ path('app_pokemon_edit', {'id': pokemon.id}) }}" class="btn btn-warning">edit</a>

		<button>{{ include('pokemon/_delete_form.html.twig') }}</button>
	</div>
</div></div>{% endblock %}
