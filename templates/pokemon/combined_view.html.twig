{# templates/pokemon/combined_view.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Pokémon - Résultats API
{% endblock %}

{% block body %}
	<h1>Résultats de l'API Pokémon</h1>

	{% for message in app.flashes('success') %}
		<div class="alert alert-success">
			{{ message }}
		</div>
	{% endfor %}

	{% if data is defined and data.results is defined %}
		<div class="pokemon-grid">
			{% for pokemon in data.results %}
				<div class="pokemon-card">
					<img src="{{ pokemon.sprite }}" alt="{{ pokemon.name }}">
					<h3>{{ pokemon.name|capitalize }}</h3>
					<form action="{{ path('add_to_team', {'id': pokemon.id}) }}" method="post">
						<input type="hidden" name="name" value="{{ pokemon.name }}">
						<input type="hidden" name="sprite" value="{{ pokemon.sprite }}">
						<button type="submit" class="btn btn-primary">Ajouter à l'équipe</button>
					</form>
				</div>
			{% endfor %}
		</div>

		<div class="pagination">
			{% if data.previous %}
				<a href="{{ path('api_results', {'page': data.currentPage - 1}) }}">Précédent</a>
			{% endif %}

			Page
			{{ data.currentPage }}
			sur
			{{ data.totalPages }}

			{% if data.next %}
				<a href="{{ path('api_results', {'page': data.currentPage + 1}) }}">Suivant</a>
			{% endif %}
			{{ dump(data.previous) }}
			{{ dump(data.next) }}
			{{ dump(data.currentPage) }}
			{{ dump(data.totalPages) }}
		</div>
	{% else %}
		<p>Aucun résultat disponible.</p>
	{% endif %}
{% endblock %}
