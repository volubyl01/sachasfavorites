	<div class="pokemon-grid">
		{% for pokemon in pokemons %}
			<div class="pokemon-card">
				<img src="{{ pokemon.sprite }}" alt="{{ pokemon.name }}" class="pokemon-sprite">
				<h3>{{ pokemon.name|capitalize }}</h3>
				<a href="{{ path('add_to_team', {'id': pokemon.id}) }}?sprite={{ pokemon.sprite|url_encode }}" class="btn btn-primary">Ajouter à la liste de Sacha</a>

			</div>
		{% endfor %}
	</ul>

	{% for message in app.flashes('success') %}
