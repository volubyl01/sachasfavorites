{% extends 'base.html.twig' %}

{% block title %}Liste des Pokémon
{% endblock %}

{% block body %}
	<h1>Liste des Pokémon</h1>

	{% for message in app.flashes('success') %}
		<div class="alert alert-success">
			{{ message }}
		</div>
	{% endfor %}

